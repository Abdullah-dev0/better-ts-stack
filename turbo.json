{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"]
    },
    "type:check": {
      "dependsOn": ["^type:check"]
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": false
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
